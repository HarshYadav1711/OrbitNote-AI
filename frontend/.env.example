# Frontend environment (set in Vercel project settings for production builds)

# API base URL. Omit or use /api when the host proxies /api to the backend.
# VITE_API_BASE=/api

# Cross-origin backend (Vercel frontend + Render/Railway API).
# Production builds use frontend/.env.production when present.
# VITE_API_BASE=https://your-api.onrender.com

# Local dev only — override Vite proxy target (default http://localhost:8000)
# VITE_DEV_API_PROXY=http://localhost:8000
