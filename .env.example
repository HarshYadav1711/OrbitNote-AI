# Copy to .env at the repository root (backend loads it via pydantic-settings)

# SQLite (default — no Docker required)
DATABASE_URL=sqlite:///./data/orbitnote.db

# Optional: PostgreSQL via docker compose
# DATABASE_URL=postgresql://orbitnote:orbitnote@localhost:5432/orbitnote

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173
