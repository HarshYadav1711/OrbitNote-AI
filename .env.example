# Copy to .env at the repository root (backend loads it via pydantic-settings)

# development | production (production enables secure cookies and validates JWT_SECRET)
ENVIRONMENT=development

# SQLite (default — no Docker required)
DATABASE_URL=sqlite:///./data/orbitnote.db

# Optional: PostgreSQL via docker compose
# DATABASE_URL=postgresql://orbitnote:orbitnote@localhost:5432/orbitnote

# Auth (required in production)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256
COOKIE_NAME=orbitnote_token

# Frontend URLs (CORS + share links) — comma-separated for multiple origins
CORS_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Production cookie overrides (optional; defaults when ENVIRONMENT=production)
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# Render/Railway set PORT automatically; local default is 8000
# PORT=8000

# Optional: Ollama for AI assist (falls back to local rules when unavailable)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=30

# Set to 1 in tests to skip Alembic on startup
# DISABLE_MIGRATIONS=1

# Backend log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
